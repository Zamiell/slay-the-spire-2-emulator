<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <NativeLib>Shared</NativeLib>
    <TargetFramework>net9.0</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <TrimmerRootDescriptor Include="ILLink.Roots.xml" />
    <UnmanagedEntryPointsAssembly Include="Sts2Emulator" />
    <!--
      ILC 9.x does not emit export aliases for [UnmanagedCallersOnly] in the primary assembly.
      Wire them manually: short public name = NativeAOT mangled internal name.
    -->
    <LinkerArg Include="/EXPORT:Sts2_ObsSize=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ObsSize" />
    <LinkerArg Include="/EXPORT:Sts2_MaxEnemies=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_MaxEnemies" />
    <LinkerArg Include="/EXPORT:Sts2_NativeApiVersion=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_NativeApiVersion" />
    <LinkerArg Include="/EXPORT:Sts2_Create=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_Create" />
    <LinkerArg Include="/EXPORT:Sts2_Reset=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_Reset" />
    <LinkerArg Include="/EXPORT:Sts2_ResetEncounter=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetEncounter" />
    <LinkerArg Include="/EXPORT:Sts2_ResetWithDeck=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetWithDeck" />
    <LinkerArg Include="/EXPORT:Sts2_ResetWithDeckAndEncounter=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetWithDeckAndEncounter" />
    <LinkerArg Include="/EXPORT:Sts2_ResetWithDeckEncounterAndRelics=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetWithDeckEncounterAndRelics" />
    <LinkerArg Include="/EXPORT:Sts2_ResetRunCombat=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetRunCombat" />
    <LinkerArg Include="/EXPORT:Sts2_ResetRunCombatPreShuffled=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ResetRunCombatPreShuffled" />
    <LinkerArg Include="/EXPORT:Sts2_Step=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_Step" />
    <LinkerArg Include="/EXPORT:Sts2_StepTargeted=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_StepTargeted" />
    <LinkerArg Include="/EXPORT:Sts2_PlayerWon=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_PlayerWon" />
    <LinkerArg Include="/EXPORT:Sts2_EncounterId=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_EncounterId" />
    <LinkerArg Include="/EXPORT:Sts2_GetShuffleRngCallCount=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_GetShuffleRngCallCount" />
    <LinkerArg Include="/EXPORT:Sts2_GetNicheRngCallCount=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_GetNicheRngCallCount" />
    <LinkerArg Include="/EXPORT:Sts2_ActionCount=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ActionCount" />
    <LinkerArg Include="/EXPORT:Sts2_ValidActions=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_ValidActions" />
    <LinkerArg Include="/EXPORT:Sts2_Destroy=Sts2Emulator_Sts2Emulator_Interop_NativeExports__Sts2_Destroy" />
  </ItemGroup>
</Project>
